<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Kadens{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.1em%22 font-size=%22104%22>📓</text></svg>">

        {# PWA (Phase 9) — installabilité + consultation offline. #}
        <meta name="theme-color" content="#b7532e">
        <link rel="manifest" href="/manifest.json">
        <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png">
        <meta name="mobile-web-app-capable" content="yes">
        <meta name="apple-mobile-web-app-capable" content="yes">
        <meta name="apple-mobile-web-app-title" content="Kadens">
        <meta name="apple-mobile-web-app-status-bar-style" content="default">

        {% block stylesheets %}
            {# Polices « Carnet clair » self-hostées : chargées via AssetMapper
               (app.css → fonts.css). Plus de dépendance Google Fonts. #}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        {% if app.user %}
            {{ include('components/_header.html.twig') }}
        {% endif %}
        <main class="kd-page">
            {% block body %}{% endblock %}
        </main>
    </body>
</html>
