<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Kadens{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.1em%22 font-size=%22104%22>📓</text></svg>">

        {% block stylesheets %}
            {# Polices « Carnet clair » — voir docs/design-system.md §3.
               À self-héberger en Phase 9 (PWA) pour la consultation offline. #}
            <link rel="preconnect" href="https://fonts.googleapis.com">
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
            <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Instrument+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        {% if app.user %}
            <header>
                <nav>
                    <a href="{{ path('app_exercise_index') }}">Exercices</a>
                    <a href="{{ path('app_workout_index') }}">Séances</a>
                    <span>{{ app.user.userIdentifier }}</span>
                    <a href="{{ path('app_logout') }}">Déconnexion</a>
                </nav>
            </header>
        {% endif %}
        {% block body %}{% endblock %}
    </body>
</html>
