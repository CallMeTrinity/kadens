<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Kadens{% endblock %}</title>
        <link rel="icon" href="{{ asset('icons/kadens.png') }}" type="image/png">

        {# Mode hors connexion / PWA suspendu (voir CLAUDE.md §6). On garde juste
           la teinte de barre navigateur, sans manifest ni service worker. #}
        <meta name="theme-color" content="#b7532e">

        {% block stylesheets %}
            {# Polices « Carnet clair » self-hostées : chargées via AssetMapper
               (app.css → fonts.css). Plus de dépendance Google Fonts. #}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        {% if app.user %}
            {{ include('components/_header.html.twig') }}
        {% endif %}
        <main class="{% block main_class %}kd-page{% endblock %}">
            {% block body %}{% endblock %}
        </main>
    </body>
</html>
