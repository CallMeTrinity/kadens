{% extends 'base.html.twig' %}

{% block title %}Calendrier — {{ monthLabel }}{% endblock %}

{% block body %}
    {% set dayNames = {1: 'Lun', 2: 'Mar', 3: 'Mer', 4: 'Jeu', 5: 'Ven', 6: 'Sam', 7: 'Dim'} %}

    {% for message in app.flashes('success') %}
        <div class="kd-flash" role="status">{{ ux_icon('lucide:circle-check') }}{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="kd-flash kd-flash--error" role="alert">{{ ux_icon('lucide:calendar-x') }}{{ message }}</div>
    {% endfor %}

    <div class="kd-pagehead">
        <div>
            <p class="kd-eyebrow">Planning</p>
            <h1 class="kd-title">{{ monthLabel }}</h1>
        </div>

        <nav class="kd-actionbar__end" aria-label="Navigation du calendrier">
            <a class="kd-btn kd-btn--secondary kd-btn--sm" href="{{ path('app_calendar_month', {year: prev.year, month: prev.month}) }}" aria-label="Mois précédent">
                {{ ux_icon('lucide:arrow-left') }}
            </a>
            <a class="kd-btn kd-btn--ghost kd-btn--sm" href="{{ path('app_calendar_index') }}">Aujourd'hui</a>
            <a class="kd-btn kd-btn--secondary kd-btn--sm" href="{{ path('app_calendar_month', {year: next.year, month: next.month}) }}" aria-label="Mois suivant">
                {{ ux_icon('lucide:arrow-right') }}
            </a>
            <a class="kd-btn kd-btn--secondary kd-btn--sm" href="{{ path('app_export_schedule', {year: year, month: month}) }}">
                {{ ux_icon('lucide:file-down') }} Exporter
            </a>
        </nav>
    </div>

    <div class="kd-calbar">
        <details class="kd-caladd">
            <summary>{{ ux_icon('lucide:calendar-plus') }} Poser une séance</summary>
            {{ form_start(scheduleForm, {attr: {class: 'kd-caladd__form'}}) }}
                {{ form_row(scheduleForm.workout) }}
                {{ form_row(scheduleForm.scheduledDate) }}
                <button type="submit" class="kd-btn kd-btn--primary">Planifier</button>
            {{ form_end(scheduleForm) }}
        </details>

        <details class="kd-caladd">
            <summary>{{ ux_icon('lucide:layers') }} Instancier un plan</summary>
            {{ form_start(instantiateForm, {attr: {class: 'kd-caladd__form'}}) }}
                {{ form_row(instantiateForm.planTemplate) }}
                {{ form_row(instantiateForm.startDate) }}
                <button type="submit" class="kd-btn kd-btn--primary">Instancier</button>
            {{ form_end(instantiateForm) }}
        </details>

        {% if instantiatedPlans|length %}
            <details class="kd-caladd">
                <summary>{{ ux_icon('lucide:calendar-x') }} Retirer un plan du planning</summary>
                <form method="post" action="{{ path('app_scheduled_workout_clear_plan') }}" class="kd-caladd__form"
                      onsubmit="return confirm('Retirer ce plan et TOUTES ses séances du planning (y compris les séances faites) ? Le plan lui-même est conservé.');">
                    <input type="hidden" name="_token" value="{{ csrf_token('clear_plan') }}">
                    <input type="hidden" name="year" value="{{ year }}">
                    <input type="hidden" name="month" value="{{ month }}">
                    <div class="kd-field">
                        <select name="planId" class="kd-input kd-select" required>
                            <option value="" disabled selected>Choisir un plan instancié…</option>
                            {% for plan in instantiatedPlans %}
                                <option value="{{ plan.id }}">{{ plan.title }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <button type="submit" class="kd-btn kd-btn--danger">{{ ux_icon('lucide:trash-2') }} Retirer du planning</button>
                </form>
            </details>
        {% endif %}
    </div>

    <div class="kd-cal">
        <div class="kd-cal__grid">
            {% for iso, label in dayNames %}
                <div class="kd-cal__dow">{{ label }}</div>
            {% endfor %}

            {% for week in weeks %}
                {% for cell in week %}
                    <div class="kd-calday{{ not cell.inMonth ? ' kd-calday--out' }}{{ cell.isToday ? ' kd-calday--today' }}">
                        <span class="kd-calday__num">{{ cell.date|date('j') }}</span>

                        {% if cell.scheduled|length %}
                            <div class="kd-calday__events">
                                {% for scheduled in cell.scheduled %}
                                    {% set st = scheduled.status.value %}
                                    <div data-controller="dialog">
                                        <button type="button" class="kd-calevent kd-calevent--{{ st }}" data-action="dialog#open">
                                            <span class="kd-calevent__dot"></span>
                                            <span class="kd-calevent__title">{{ scheduled.workout.title }}</span>
                                        </button>

                                        <dialog class="kd-modal" data-dialog-target="dialog" data-action="click->dialog#backdrop">
                                            <div class="kd-modal__card">
                                                <div class="kd-modal__head">
                                                    <div>
                                                        <h2 class="kd-modal__title">{{ scheduled.workout.title }}</h2>
                                                        <p class="kd-modal__sub">{{ scheduled.scheduledDate|date('d/m/Y') }} · {{ scheduled.status.label }}</p>
                                                    </div>
                                                    <button type="button" class="kd-modal__close" data-action="dialog#close" aria-label="Fermer">
                                                        {{ ux_icon('lucide:x') }}
                                                    </button>
                                                </div>

                                                <a class="kd-btn kd-btn--secondary kd-btn--block" href="{{ path('app_workout_show', {id: scheduled.workout.id}) }}">
                                                    {{ ux_icon('lucide:external-link') }} Voir la séance
                                                </a>

                                                {# Prévu vs réalisé : marquer fait/manqué et noter un écart léger. #}
                                                <div class="kd-modal__section">
                                                    <p class="kd-modal__section-title">Statut</p>
                                                    <form method="post" action="{{ path('app_scheduled_workout_status', {id: scheduled.id}) }}" class="kd-modal__form">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('status' ~ scheduled.id) }}">
                                                        <div class="kd-field">
                                                            <select name="status" class="kd-input kd-select">
                                                                {% for status in statuses %}
                                                                    <option value="{{ status.value }}"{{ status == scheduled.status ? ' selected' }}>{{ status.label }}</option>
                                                                {% endfor %}
                                                            </select>
                                                        </div>
                                                        <div class="kd-field">
                                                            <textarea name="completionNotes" rows="2" class="kd-input kd-input--area" placeholder="Écart / ressenti (optionnel)">{{ scheduled.completionNotes }}</textarea>
                                                        </div>
                                                        <button type="submit" class="kd-btn kd-btn--primary">{{ ux_icon('lucide:save') }} Enregistrer</button>
                                                    </form>
                                                </div>

                                                <div class="kd-modal__section">
                                                    <p class="kd-modal__section-title">Déplacer</p>
                                                    <form method="post" action="{{ path('app_scheduled_workout_move', {id: scheduled.id}) }}" class="kd-modal__inline">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('move' ~ scheduled.id) }}">
                                                        <div class="kd-field">
                                                            <input type="date" name="scheduledDate" value="{{ scheduled.scheduledDate|date('Y-m-d') }}" class="kd-input" required>
                                                        </div>
                                                        <button type="submit" class="kd-btn kd-btn--secondary">{{ ux_icon('lucide:calendar-clock') }} Déplacer</button>
                                                    </form>
                                                </div>

                                                <div class="kd-modal__section">
                                                    <form method="post" action="{{ path('app_scheduled_workout_delete', {id: scheduled.id}) }}" onsubmit="return confirm('Retirer cette séance du planning ?');">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ scheduled.id) }}">
                                                        <button type="submit" class="kd-btn kd-btn--danger">{{ ux_icon('lucide:trash-2') }} Retirer du planning</button>
                                                    </form>
                                                </div>
                                            </div>
                                        </dialog>
                                    </div>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                {% endfor %}
            {% endfor %}
        </div>
    </div>
{% endblock %}
