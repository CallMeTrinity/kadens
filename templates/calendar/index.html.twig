{% extends 'base.html.twig' %}

{% block title %}Calendrier — {{ monthLabel }}{% endblock %}

{% block body %}
    {% for message in app.flashes('success') %}
        <p role="status">{{ message }}</p>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <p role="alert" style="color:var(--color-status-missed)">{{ message }}</p>
    {% endfor %}

    {% set dayNames = {1: 'Lun', 2: 'Mar', 3: 'Mer', 4: 'Jeu', 5: 'Ven', 6: 'Sam', 7: 'Dim'} %}
    {% set statusColors = {
        'planned': 'var(--color-status-planned)',
        'done': 'var(--color-status-done)',
        'missed': 'var(--color-status-missed)'
    } %}

    <header style="display:flex; align-items:baseline; gap:1rem">
        <h1 style="font-family:var(--font-display)">{{ monthLabel }}</h1>
        <nav style="display:flex; gap:.75rem">
            <a href="{{ path('app_calendar_month', {year: prev.year, month: prev.month}) }}">← Mois précédent</a>
            <a href="{{ path('app_calendar_index') }}">Aujourd'hui</a>
            <a href="{{ path('app_calendar_month', {year: next.year, month: next.month}) }}">Mois suivant →</a>
        </nav>
    </header>

    <section style="display:flex; gap:2rem; flex-wrap:wrap; margin:1rem 0">
        <details>
            <summary>Poser une séance</summary>
            {{ form_start(scheduleForm) }}
                {{ form_row(scheduleForm.workout) }}
                {{ form_row(scheduleForm.scheduledDate) }}
                <button type="submit">Planifier</button>
            {{ form_end(scheduleForm) }}
        </details>

        <details>
            <summary>Instancier un plan</summary>
            {{ form_start(instantiateForm) }}
                {{ form_row(instantiateForm.planTemplate) }}
                {{ form_row(instantiateForm.startDate) }}
                <button type="submit">Instancier</button>
            {{ form_end(instantiateForm) }}
        </details>
    </section>

    <div style="display:grid; grid-template-columns:repeat(7, minmax(0, 1fr)); gap:1px">
        {% for iso, label in dayNames %}
            <div style="font-family:var(--font-mono); text-transform:uppercase; font-size:.7rem; color:var(--color-text-faint); padding:.25rem .5rem">{{ label }}</div>
        {% endfor %}

        {% for week in weeks %}
            {% for cell in week %}
                <div style="min-height:6rem; border:1px solid var(--color-border-cell); padding:.35rem;
                            {{ cell.inMonth ? 'background:var(--color-surface-raised)' : 'background:var(--color-surface-subtle)' }}
                            {{ cell.isToday ? '; outline:2px solid var(--color-primary)' : '' }}">
                    <div style="font-family:var(--font-mono); font-size:.75rem; {{ cell.inMonth ? 'color:var(--color-text-secondary)' : 'color:var(--color-text-faint)' }}">
                        {{ cell.date|date('j') }}
                    </div>

                    {% for scheduled in cell.scheduled %}
                        <div style="border-left:3px solid {{ statusColors[scheduled.status.value] }}; background:var(--color-fill); border-radius:0 var(--kd-radius-md) var(--kd-radius-md) 0; padding:.15rem .35rem; margin-top:.25rem; font-size:.75rem">
                            <a href="{{ path('app_workout_show', {id: scheduled.workout.id}) }}">{{ scheduled.workout.title }}</a>
                            <span style="font-family:var(--font-mono); color:{{ statusColors[scheduled.status.value] }}"> · {{ scheduled.status.label }}</span>

                            {% if scheduled.completionNotes %}
                                <p style="margin:.2rem 0 0; color:var(--color-text-secondary); font-style:italic">{{ scheduled.completionNotes }}</p>
                            {% endif %}

                            {# Prévu vs réalisé : cocher fait/manqué et noter un écart léger. #}
                            <form method="post" action="{{ path('app_scheduled_workout_status', {id: scheduled.id}) }}" style="margin:.25rem 0">
                                <input type="hidden" name="_token" value="{{ csrf_token('status' ~ scheduled.id) }}">
                                <label style="display:block; font-family:var(--font-mono); font-size:.65rem; color:var(--color-text-faint)">Statut
                                    <select name="status" style="width:100%">
                                        {% for status in statuses %}
                                            <option value="{{ status.value }}"{{ status == scheduled.status ? ' selected' : '' }}>{{ status.label }}</option>
                                        {% endfor %}
                                    </select>
                                </label>
                                <textarea name="completionNotes" rows="2" placeholder="Écart / ressenti (optionnel)" style="width:100%; margin-top:.2rem">{{ scheduled.completionNotes }}</textarea>
                                <button type="submit">Enregistrer</button>
                            </form>

                            <details>
                                <summary style="cursor:pointer; font-size:.7rem; color:var(--color-text-faint)">Déplacer / retirer</summary>
                                <form method="post" action="{{ path('app_scheduled_workout_move', {id: scheduled.id}) }}" style="margin:.25rem 0">
                                    <input type="hidden" name="_token" value="{{ csrf_token('move' ~ scheduled.id) }}">
                                    <input type="date" name="scheduledDate" value="{{ scheduled.scheduledDate|date('Y-m-d') }}" required>
                                    <button type="submit">Déplacer</button>
                                </form>
                                {{ include('workout/_action_form.html.twig', {
                                    action: path('app_scheduled_workout_delete', {id: scheduled.id}),
                                    token: csrf_token('delete' ~ scheduled.id),
                                    label: 'Retirer',
                                    confirm: 'Retirer cette séance du planning ?'
                                }) }}
                            </details>
                        </div>
                    {% endfor %}
                </div>
            {% endfor %}
        {% endfor %}
    </div>
{% endblock %}
