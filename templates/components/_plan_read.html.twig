{# Rendu lecture seule d'un plan mis à plat par PlanFlattener::flattenPlanTemplate.
   Auto-suffisant : aucun AJAX post-rendu, condition du cache offline (Phase 9).
   Attend une variable `flat` (grille dense semaines × jours). #}
{% set template = flat.template %}
{% set dayNames = {1: 'Lun', 2: 'Mar', 3: 'Mer', 4: 'Jeu', 5: 'Ven', 6: 'Sam', 7: 'Dim'} %}

<header class="kd-workouthead">
    <p class="kd-eyebrow">Plan</p>
    <h1 class="kd-title">{{ template.title }}</h1>

    <div class="kd-workouthead__meta">
        <span class="kd-badge">{{ ux_icon('lucide:calendar-range') }} {{ template.durationWeeks }} semaine{{ template.durationWeeks > 1 ? 's' }}</span>
        <span class="kd-badge">{{ ux_icon('lucide:clipboard-list') }} {{ template.planItems|length }} séance{{ template.planItems|length > 1 ? 's' }}</span>
    </div>

    {% if template.description %}
        <p class="kd-workouthead__desc">{{ template.description|nl2br }}</p>
    {% endif %}
</header>

<div class="kd-planweeks">
    {% for week in flat.weeks %}
        {% set weekCount = 0 %}
        {% for day in week.days %}{% set weekCount = weekCount + day.items|length %}{% endfor %}
        <section class="kd-planweek">
            <div class="kd-planweek__head">
                <span class="kd-planweek__num">Semaine {{ week.weekNumber }}</span>
                <span class="kd-planweek__count">{{ weekCount }} séance{{ weekCount > 1 ? 's' }}</span>
            </div>

            <div class="kd-plangrid">
                {% for day in week.days %}
                    <div class="kd-planday{{ day.items is empty ? ' is-empty' }}">
                        <div class="kd-planday__name">{{ dayNames[day.dayOfWeek] }}</div>
                        <div class="kd-planday__items">
                            {% for entry in day.items %}
                                <div class="kd-planentry">
                                    <a class="kd-planday__item" href="{{ path('app_workout_show', {id: entry.item.workout.id}) }}">
                                        {{ ux_icon('lucide:clipboard-list') }}
                                        <span>{{ entry.workout.workout.title }}</span>
                                    </a>
                                    {% if entry.item.notes %}<p class="kd-planday__notes">{{ entry.item.notes|nl2br }}</p>{% endif %}
                                </div>
                            {% else %}
                                <span class="kd-planday__rest">Repos</span>
                            {% endfor %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        </section>
    {% endfor %}
</div>
