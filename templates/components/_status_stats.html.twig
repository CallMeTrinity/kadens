{# Synthèse « prévu vs réalisé » pour un jeu de compteurs (Phase 7).
   Paramètres :
     - stats = {done, missed, planned, total, adherence}
       adherence = done / (done + missed), ou null si rien d'échu.
     - hero (bool, défaut false) : grand format pour le bloc du mois.
   Couleur = statut (fait/prévu/manqué), seul cas où elle ne code pas l'activité. #}
{% set settled = stats.done + stats.missed %}

{% if stats.total == 0 %}
    <p class="kd-observance__empty">{{ ux_icon('lucide:calendar-off') }} Aucune séance planifiée.</p>
{% else %}
    <div class="kd-observance{{ hero|default(false) ? ' kd-observance--hero' }}">
        <div class="kd-observance__figure">
            <span class="kd-observance__pct">{{ stats.adherence is null ? '—' : (stats.adherence * 100)|round ~ '%' }}</span>
            <span class="kd-observance__cap">
                Observance
                <span class="kd-observance__sub">{{ stats.done }}/{{ settled }} séance{{ settled > 1 ? 's' : '' }} échue{{ settled > 1 ? 's' : '' }}</span>
            </span>
        </div>

        {# Barre proportionnelle faite / manquée / prévue. #}
        <div class="kd-obar" role="img" aria-label="{{ stats.done }} faites, {{ stats.missed }} manquées, {{ stats.planned }} prévues">
            {% for key, count in {'done': stats.done, 'missed': stats.missed, 'planned': stats.planned} %}
                {% if count > 0 %}
                    <span class="kd-obar__seg kd-obar__seg--{{ key }}" style="flex:{{ count }}"></span>
                {% endif %}
            {% endfor %}
        </div>

        <ul class="kd-olegend">
            <li class="kd-olegend__item kd-olegend__item--done"><span class="kd-olegend__dot"></span>{{ stats.done }} faite{{ stats.done > 1 ? 's' : '' }}</li>
            <li class="kd-olegend__item kd-olegend__item--missed"><span class="kd-olegend__dot"></span>{{ stats.missed }} manquée{{ stats.missed > 1 ? 's' : '' }}</li>
            <li class="kd-olegend__item kd-olegend__item--planned"><span class="kd-olegend__dot"></span>{{ stats.planned }} prévue{{ stats.planned > 1 ? 's' : '' }}</li>
        </ul>
    </div>
{% endif %}
