{% extends 'base.html.twig' %}

{% block title %}Éditer {{ exercise.name }}{% endblock %}

{% block body %}
    <a href="{{ path('app_exercise_show', {id: exercise.id}) }}" class="kd-backlink">
        {{ ux_icon('lucide:arrow-left') }} {{ exercise.name }}
    </a>

    <div class="kd-pagehead">
        <div>
            <p class="kd-eyebrow">Bibliothèque</p>
            <h1 class="kd-title">Éditer « {{ exercise.name }} »</h1>
        </div>
    </div>

    <div class="kd-card" style="max-width:640px;">
        {{ include('exercise/_form.html.twig', {button_label: 'Mettre à jour'}) }}
    </div>
{% endblock %}
