{% extends 'base.html.twig' %}

{% block title %}{{ exercise.name }}{% endblock %}

{% block body %}
    <h1>{{ exercise.name }}</h1>

    <dl>
        <dt>Activité</dt>
        <dd>{{ exercise.activity ? exercise.activity.label : '' }}</dd>

        <dt>Zones travaillées</dt>
        <dd>
            {% for area in exercise.targetAreas %}
                {{ area.label }}{{ not loop.last ? ', ' }}
            {% else %}
                —
            {% endfor %}
        </dd>

        <dt>Description</dt>
        <dd>{{ exercise.description ?: '—' }}</dd>

        <dt>Lien média</dt>
        <dd>
            {% if exercise.mediaUrl %}
                <a href="{{ exercise.mediaUrl }}" target="_blank" rel="noopener">{{ exercise.mediaUrl }}</a>
            {% else %}
                —
            {% endif %}
        </dd>
    </dl>

    {% if is_granted('EDIT', exercise) %}
        <a href="{{ path('app_exercise_edit', {id: exercise.id}) }}">Éditer</a>
    {% endif %}

    {% if is_granted('DELETE', exercise) %}
        {{ include('exercise/_delete_form.html.twig') }}
    {% endif %}

    <p><a href="{{ path('app_exercise_index') }}">Retour à la liste</a></p>
{% endblock %}
