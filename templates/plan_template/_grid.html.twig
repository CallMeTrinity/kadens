{# Contenu de #plan-grid : trame éditable semaines × 7 jours. Chaque mutation
   (ajout/retrait d'une séance dans une case) remplace ce conteneur via Turbo
   Stream. Contexte attendu (fourni par gridContext) : template, flat (sortie de
   PlanFlattener::flattenPlanTemplate), addItemForms (indexés « w{semaine}d{jour} »). #}
{% set dayNames = {1: 'Lundi', 2: 'Mardi', 3: 'Mercredi', 4: 'Jeudi', 5: 'Vendredi', 6: 'Samedi', 7: 'Dimanche'} %}

{% for week in flat.weeks %}
    <section>
        <h3>Semaine {{ week.weekNumber }}</h3>
        <div style="display:grid; grid-template-columns:repeat(7, minmax(0, 1fr)); gap:.5rem">
        {% for day in week.days %}
            <div style="border:1px solid var(--color-border); padding:.5rem">
                <strong>{{ dayNames[day.dayOfWeek] }}</strong>

                <ul>
                {% for entry in day.items %}
                    <li>
                        <a href="{{ path('app_workout_show', {id: entry.item.workout.id}) }}">{{ entry.workout.workout.title }}</a>
                        {{ include('workout/_action_form.html.twig', {
                            action: path('app_plan_template_item_delete', {id: template.id, itemId: entry.item.id}),
                            token: csrf_token('item_delete' ~ entry.item.id),
                            label: '×',
                            confirm: 'Retirer cette séance de la trame ?'
                        }) }}
                        {% if entry.item.notes %}<p>{{ entry.item.notes|nl2br }}</p>{% endif %}
                    </li>
                {% endfor %}
                </ul>

                {% set addForm = addItemForms['w' ~ week.weekNumber ~ 'd' ~ day.dayOfWeek] %}
                <details>
                    <summary>+ Séance</summary>
                    {{ form_start(addForm) }}
                        {{ form_row(addForm.workout) }}
                        {{ form_row(addForm.notes) }}
                        <button type="submit">Ajouter</button>
                    {{ form_end(addForm) }}
                </details>
            </div>
        {% endfor %}
        </div>
    </section>
{% endfor %}
