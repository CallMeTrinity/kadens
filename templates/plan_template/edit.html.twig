{% extends 'base.html.twig' %}

{% block title %}Éditer — {{ template.title }}{% endblock %}

{% block body %}
    {% for message in app.flashes('success') %}
        <p class="kd-flash" role="status">{{ ux_icon('lucide:circle-check') }} {{ message }}</p>
    {% endfor %}

    <div class="kd-actionbar">
        <a href="{{ path('app_plan_template_index') }}" class="kd-backlink">
            {{ ux_icon('lucide:arrow-left') }} Mes plans
        </a>
        <div class="kd-actionbar__end">
            <a href="{{ path('app_plan_template_show', {id: template.id}) }}" class="kd-btn kd-btn--secondary kd-btn--sm">
                {{ ux_icon('lucide:arrow-right') }} Voir le plan
            </a>
        </div>
    </div>

    <div class="kd-pagehead">
        <div>
            <p class="kd-eyebrow">Éditeur de plan</p>
            <h1 class="kd-title">{{ template.title }}</h1>
        </div>
    </div>

    {# Informations générales #}
    <section class="kd-card" style="max-width:640px;">
        <div class="kd-card__head">
            <h2 class="kd-card__title">Informations</h2>
        </div>
        {{ form_start(form) }}
            {{ form_widget(form) }}
            <div class="kd-formactions">
                <button type="submit" class="kd-btn kd-btn--primary">
                    {{ ux_icon('lucide:save') }} Enregistrer
                </button>
            </div>
        {{ form_end(form) }}
    </section>

    {# Trame — conteneur cible des Turbo Streams. Le contrôleur `plangrid` porte le
       glisser-déposer inter-cases et la mini-modale d'édition rapide. Il enveloppe
       la grille ET la modale : les mutations de trame ne touchent que le CONTENU de
       #plan-grid (action="update"), la modale et le contrôleur survivent. #}
    <section class="kd-editsection" data-controller="plangrid">
        <p class="kd-editsection__title">Trame</p>
        <p class="kd-editsection__hint">
            Glisse une séance d'un jour à l'autre. Clique une séance pour ajuster ses
            valeurs (sa progression est propre à cette semaine, les autres cases ne
            bougent pas).
        </p>
        <div id="plan-grid">
            {{ include('plan_template/_grid.html.twig') }}
        </div>

        {# Mini-modale d'édition rapide : le panneau des exercices de la copie locale
           est chargé en fetch dans #quick-panel, puis re-rendu par Turbo Stream à
           chaque enregistrement. data-turbo="false" : Turbo n'intercepte aucun
           formulaire de la modale, le contrôleur applique lui-même les streams. #}
        <dialog class="kd-modal kd-modal--quick" data-plangrid-target="dialog" data-turbo="false"
                data-action="click->plangrid#backdrop">
            <div class="kd-modal__card kd-modal__card--quick">
                <header class="kd-modal__head">
                    <span class="kd-modal__title">{{ ux_icon('lucide:sliders-horizontal') }} Édition rapide</span>
                    <div class="kd-modal__headactions">
                        <a data-plangrid-target="fullLink" href="#" class="kd-btn kd-btn--secondary kd-btn--sm">
                            {{ ux_icon('lucide:square-pen') }} Édition complète
                        </a>
                        <button type="button" class="kd-modal__close" data-action="plangrid#close" aria-label="Fermer">
                            {{ ux_icon('lucide:x') }}
                        </button>
                    </div>
                </header>
                <div id="quick-panel" class="kd-quickedit" data-plangrid-target="panel"></div>
            </div>
        </dialog>
    </section>

    {# Dupliquer #}
    <section class="kd-editsection">
        <p class="kd-editsection__title">Dupliquer</p>
        <div class="kd-card" style="max-width:640px;">
            <form method="post" action="{{ path('app_plan_template_duplicate', {id: template.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('duplicate' ~ template.id) }}">
                <button type="submit" class="kd-btn kd-btn--secondary">
                    {{ ux_icon('lucide:copy') }} Dupliquer ce plan
                </button>
            </form>
        </div>
    </section>

    {# Zone dangereuse #}
    <section class="kd-editsection">
        <p class="kd-editsection__title">Zone dangereuse</p>
        {{ include('plan_template/_delete_form.html.twig') }}
    </section>
{% endblock %}
