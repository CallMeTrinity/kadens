{% extends 'base.html.twig' %}

{% block title %}Éditer — {{ template.title }}{% endblock %}

{% block body %}
    {% for message in app.flashes('success') %}
        <p role="status">{{ message }}</p>
    {% endfor %}

    <p>
        <a href="{{ path('app_plan_template_index') }}">Retour aux plans</a>
        · <a href="{{ path('app_plan_template_show', {id: template.id}) }}">Voir le plan</a>
    </p>

    <h1>Éditer le plan</h1>

    <section>
        <h2>Informations</h2>
        {{ form_start(form) }}
            {{ form_widget(form) }}
            <button type="submit">Enregistrer</button>
        {{ form_end(form) }}
    </section>

    <section>
        <h2>Trame</h2>
        {# Conteneur cible des Turbo Streams : chaque mutation le remplace. #}
        <div id="plan-grid">
            {{ include('plan_template/_grid.html.twig') }}
        </div>
    </section>

    <section>
        <h2>Dupliquer</h2>
        <form method="post" action="{{ path('app_plan_template_duplicate', {id: template.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('duplicate' ~ template.id) }}">
            <button type="submit">Dupliquer ce plan</button>
        </form>
    </section>

    <section>
        {{ include('plan_template/_delete_form.html.twig') }}
    </section>
{% endblock %}
