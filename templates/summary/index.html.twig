{% extends 'base.html.twig' %}

{% block title %}Synthèse — {{ monthLabel }}{% endblock %}

{% block body %}
    <header style="display:flex; align-items:baseline; gap:1rem; flex-wrap:wrap">
        <h1 style="font-family:var(--font-display)">Prévu vs réalisé</h1>
        <a href="{{ path('app_calendar_month', {year: year, month: month}) }}">← Retour au calendrier</a>
    </header>

    <section style="margin:1.5rem 0">
        <div style="display:flex; align-items:baseline; gap:1rem">
            <h2 style="font-family:var(--font-display)">{{ monthLabel }}</h2>
            <nav style="display:flex; gap:.75rem; font-size:.85rem">
                <a href="{{ path('app_summary_month', {year: prev.year, month: prev.month}) }}">← Mois précédent</a>
                <a href="{{ path('app_summary_index') }}">Ce mois-ci</a>
                <a href="{{ path('app_summary_month', {year: next.year, month: next.month}) }}">Mois suivant →</a>
            </nav>
        </div>
        {{ include('components/_status_stats.html.twig', {stats: monthStats}) }}
    </section>

    <section style="margin:1.5rem 0">
        <h2 style="font-family:var(--font-display)">Par plan instancié</h2>
        <p style="color:var(--color-text-faint); font-size:.85rem">Toutes dates confondues, sur l'ensemble de votre planning.</p>

        {% if plans is empty %}
            <p style="color:var(--color-text-faint)">Aucune séance planifiée pour l'instant.</p>
        {% else %}
            {% for plan in plans %}
                <article style="border:1px solid var(--color-border-cell); border-radius:var(--kd-radius-md); padding:1rem; margin-top:1rem">
                    <h3 style="font-family:var(--font-display); margin:0 0 .5rem">
                        {% if plan.planId %}
                            <a href="{{ path('app_plan_template_show', {id: plan.planId}) }}">{{ plan.planTitle }}</a>
                        {% else %}
                            Séances hors plan
                        {% endif %}
                    </h3>
                    {{ include('components/_status_stats.html.twig', {stats: plan.stats}) }}
                </article>
            {% endfor %}
        {% endif %}
    </section>
{% endblock %}
