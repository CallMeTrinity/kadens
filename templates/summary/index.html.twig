{% extends 'base.html.twig' %}

{% block title %}Synthèse — {{ monthLabel }}{% endblock %}

{% block body %}
    <div class="kd-pagehead">
        <div>
            <p class="kd-eyebrow">Synthèse</p>
            <h1 class="kd-title">Prévu vs réalisé</h1>
            <p class="kd-lead">La part de séances tenues sur les échues. On boucle sur la prévision, sans tracking détaillé.</p>
        </div>

        <nav class="kd-actionbar__end" aria-label="Navigation de la synthèse">
            <a class="kd-btn kd-btn--secondary kd-btn--sm" href="{{ path('app_summary_month', {year: prev.year, month: prev.month}) }}" aria-label="Mois précédent">
                {{ ux_icon('lucide:arrow-left') }}
            </a>
            <a class="kd-btn kd-btn--ghost kd-btn--sm" href="{{ path('app_summary_index') }}">Ce mois-ci</a>
            <a class="kd-btn kd-btn--secondary kd-btn--sm" href="{{ path('app_summary_month', {year: next.year, month: next.month}) }}" aria-label="Mois suivant">
                {{ ux_icon('lucide:arrow-right') }}
            </a>
            <a class="kd-btn kd-btn--secondary kd-btn--sm" href="{{ path('app_calendar_month', {year: year, month: month}) }}">
                {{ ux_icon('lucide:calendar-days') }} Calendrier
            </a>
        </nav>
    </div>

    {# Observance du mois — bloc mis en avant. #}
    <section class="kd-card kd-summonth">
        <div class="kd-card__head">
            <h2 class="kd-card__title">{{ ux_icon('lucide:calendar-check') }} {{ monthLabel }}</h2>
        </div>
        {{ include('components/_status_stats.html.twig', {stats: monthStats, hero: true}) }}
    </section>

    {# Détail par plan instancié — toutes dates confondues. #}
    <div class="kd-pagehead kd-pagehead--sub">
        <div>
            <p class="kd-eyebrow">Par plan instancié</p>
            <h2 class="kd-title kd-title--sm">Sur l'ensemble du planning</h2>
        </div>
    </div>

    {% if plans is empty %}
        <div class="kd-empty">
            {{ ux_icon('lucide:layers') }}
            <div>Aucune séance planifiée pour l'instant.</div>
        </div>
    {% else %}
        <div class="kd-grid kd-grid--2">
            {% for plan in plans %}
                <article class="kd-card kd-summplan">
                    <div class="kd-summplan__head">
                        {% if plan.planId %}
                            <a class="kd-summplan__title" href="{{ path('app_plan_template_show', {id: plan.planId}) }}">
                                {{ ux_icon('lucide:layers') }} {{ plan.planTitle }}
                            </a>
                        {% else %}
                            <span class="kd-summplan__title kd-summplan__title--loose">
                                {{ ux_icon('lucide:calendar') }} Séances hors plan
                            </span>
                        {% endif %}
                    </div>
                    {{ include('components/_status_stats.html.twig', {stats: plan.stats}) }}
                </article>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
