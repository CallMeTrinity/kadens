{# Un bloc dans le compositeur (style 3a). En-tête inline (rôle / libellé / tours,
   déplacer, supprimer) puis les exercices en lignes compactes. Le corps du bloc
   est une zone de dépôt (glisser depuis la bibliothèque ou réordonner une ligne).
   Contexte hérité : workout, blockForms, prescribedForms, summaries. #}
{% import 'components/_activity.html.twig' as activity %}
{% set blockForm = blockForms[block.id] %}

<article class="kd-cblock"
         data-composer-target="block"
         data-block-id="{{ block.id }}"
         data-action="click->composer#activateBlock">

    <div class="kd-cblock__head">
        {{ form_start(blockForm, { attr: { class: 'kd-cblock__form' } }) }}
            <span class="kd-cblock__dot"></span>
            {{ form_widget(blockForm.role, { attr: {
                class: 'kd-cblock__role',
                'data-action': 'change->composer#submitForm',
            } }) }}
            {{ form_widget(blockForm.label, { attr: {
                class: 'kd-cblock__label',
                placeholder: 'intitulé libre',
                'data-action': 'change->composer#submitForm',
            } }) }}
            <div class="kd-cblock__rounds">
                <button type="button" class="kd-cblock__step" data-action="composer#roundsDec" aria-label="Moins de tours">−</button>
                {{ ux_icon('lucide:repeat') }}
                {{ form_widget(blockForm.rounds, { attr: {
                    class: 'kd-cblock__roundsval',
                    'data-action': 'change->composer#submitForm',
                    'aria-label': 'Nombre de tours',
                } }) }}
                <span class="kd-cblock__roundslabel">tours</span>
                <button type="button" class="kd-cblock__step" data-action="composer#roundsInc" aria-label="Plus de tours">+</button>
            </div>
        {{ form_end(blockForm) }}

        <div class="kd-cblock__actions">
            {{ include('workout/_action_form.html.twig', {
                action: path('app_workout_block_move', {id: workout.id, blockId: block.id, direction: 'up'}),
                token: csrf_token('block_move' ~ block.id),
                icon: 'lucide:chevron-up',
                label: 'Monter le bloc'
            }) }}
            {{ include('workout/_action_form.html.twig', {
                action: path('app_workout_block_move', {id: workout.id, blockId: block.id, direction: 'down'}),
                token: csrf_token('block_move' ~ block.id),
                icon: 'lucide:chevron-down',
                label: 'Descendre le bloc'
            }) }}
            {{ include('workout/_action_form.html.twig', {
                action: path('app_workout_block_delete', {id: workout.id, blockId: block.id}),
                token: csrf_token('block_delete' ~ block.id),
                icon: 'lucide:x',
                variant: 'danger',
                label: 'Supprimer le bloc'
            }) }}
        </div>
    </div>

    <div class="kd-cblock__items" data-composer-target="items" data-block-id="{{ block.id }}">
        {# Tri par position en mémoire : après une mutation (ajout/réordonnancement),
           la PersistentCollection Doctrine garde son ordre de chargement, le #[OrderBy]
           ne s'appliquant qu'au load DB. On mirroir donc l'ordre « position ASC » ici,
           sinon le re-render du stream montre l'ordre périmé (correct au rechargement). #}
        {% for prescribed in block.prescribedExercises|sort((a, b) => a.position <=> b.position) %}
            {% set ex = prescribed.exercise %}
            {% set mod = ex ? activity.modifier(ex.activity) : '' %}
            <div class="kd-cexo"
                 data-composer-target="exo"
                 data-prescribed-id="{{ prescribed.id }}"
                 data-block-id="{{ block.id }}">
                <div class="kd-cexo__row">
                    <span class="kd-cexo__handle" title="Glisser pour réordonner">{{ ux_icon('lucide:grip-vertical') }}</span>
                    <span class="kd-cexo__code{{ mod ? ' kd-cexo__code--' ~ mod }}">{{ ex ? ex.name|slice(0, 2)|upper : '??' }}</span>
                    <div class="kd-cexo__body">
                        <div class="kd-cexo__name">{{ ex ? ex.name : 'Exercice supprimé' }}</div>
                        <div class="kd-cexo__type">{{ prescribed.prescriptionType ? prescribed.prescriptionType.label }}</div>
                    </div>
                    {% if summaries[prescribed.id]|default('') is not empty %}
                        <span class="kd-cexo__pill">{{ summaries[prescribed.id] }}</span>
                    {% endif %}
                    <button type="button" class="kd-cexo__btn" data-action="composer#toggleParams" title="Paramètres" aria-label="Paramètres">
                        {{ ux_icon('lucide:sliders-horizontal') }}
                    </button>
                    {{ include('workout/_action_form.html.twig', {
                        action: path('app_workout_prescribed_delete', {id: workout.id, prescribedId: prescribed.id}),
                        token: csrf_token('prescribed_delete' ~ prescribed.id),
                        icon: 'lucide:x',
                        variant: 'danger',
                        label: 'Retirer l\'exercice'
                    }) }}
                </div>

                <div class="kd-cexo__params" hidden>
                    {{ include('workout/_prescribed_form.html.twig', {
                        form: prescribedForms[prescribed.id],
                        submit_label: 'Enregistrer l\'exercice'
                    }) }}
                    <div class="kd-cexo__reorder">
                        {{ include('workout/_action_form.html.twig', {
                            action: path('app_workout_prescribed_move', {id: workout.id, prescribedId: prescribed.id, direction: 'up'}),
                            token: csrf_token('prescribed_move' ~ prescribed.id),
                            icon: 'lucide:chevron-up',
                            label: 'Monter l\'exercice'
                        }) }}
                        {{ include('workout/_action_form.html.twig', {
                            action: path('app_workout_prescribed_move', {id: workout.id, prescribedId: prescribed.id, direction: 'down'}),
                            token: csrf_token('prescribed_move' ~ prescribed.id),
                            icon: 'lucide:chevron-down',
                            label: 'Descendre l\'exercice'
                        }) }}
                    </div>
                </div>
            </div>
        {% else %}
            <div class="kd-cblock__drop">Déposez un exercice ici</div>
        {% endfor %}
    </div>
</article>
