{# Contenu de #workout-blocks. Contexte attendu (fourni par blocksContext) :
   workout, addBlockForm, blockForms, addExerciseForms, prescribedForms. #}
{% if workout.blocks is empty %}
    <div class="kd-card kd-empty">
        {{ ux_icon('lucide:layers') }}
        <div>Aucun bloc pour l'instant. Ajoute le premier ci-dessous.</div>
    </div>
{% else %}
    {% for block in workout.blocks %}
        {{ include('workout/_block.html.twig', { block: block }) }}
    {% endfor %}
{% endif %}

<section class="kd-addblock">
    <p class="kd-addblock__title">{{ ux_icon('lucide:plus') }} Ajouter un bloc</p>
    {{ form_start(addBlockForm) }}
        <div class="kd-fieldrow kd-fieldrow--tight">
            {{ form_row(addBlockForm.role) }}
            {{ form_row(addBlockForm.rounds) }}
            {{ form_row(addBlockForm.label) }}
        </div>
        <div class="kd-formactions">
            <button type="submit" class="kd-btn kd-btn--primary kd-btn--sm">
                {{ ux_icon('lucide:plus') }} Ajouter le bloc
            </button>
        </div>
    {{ form_end(addBlockForm) }}
</section>
