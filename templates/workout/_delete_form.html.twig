<form method="post" action="{{ path('app_workout_delete', {id: workout.id}) }}"
      onsubmit="return confirm('Supprimer cette séance ?');" data-turbo="false" style="display:inline;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ workout.id) }}">
    <button type="submit" class="kd-btn kd-btn--danger">
        {{ ux_icon('lucide:trash-2') }} Supprimer la séance
    </button>
</form>
