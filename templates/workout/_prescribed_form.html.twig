{# Formulaire d'un exercice prescrit (ajout ou édition). Les champs de valeurs
   pertinents sont montrés/masqués selon le type d'effort par le contrôleur
   Stimulus « prescription-fields ». Le nettoyage définitif se fait côté serveur.
   Paramètres : form (FormView), submit_label. #}
<div data-controller="prescription-fields"
     data-prescription-fields-map-value="{{ prescription_type_fields_map()|json_encode|e('html_attr') }}">
    {{ form_start(form) }}
        {{ form_row(form.exercise) }}
        {{ form_row(form.prescriptionType, { attr: {
            'data-prescription-fields-target': 'type',
            'data-action': 'prescription-fields#update',
        } }) }}

        {% for field in ['sets', 'reps', 'weightKg', 'durationSeconds', 'distanceMeters', 'paceSecondsPerKm', 'targetReps', 'capSeconds', 'intensityZone'] %}
            <div data-prescription-fields-target="field" data-field="{{ field }}">
                {{ form_row(attribute(form, field)) }}
            </div>
        {% endfor %}

        {{ form_row(form.restSeconds) }}
        {{ form_row(form.notes) }}

        <button type="submit">{{ submit_label|default('Enregistrer') }}</button>
    {{ form_end(form) }}
</div>
