{# Contenu de #quick-panel : les exercices d'une séance, groupés par bloc, avec
   leurs paramètres éditables. Injecté dans la mini-modale de l'éditeur de plan
   (fetch) et re-rendu par Turbo Stream à chaque enregistrement (action="update").
   Contexte (quickPanelContext) : workout, prescribedForms, summaries.

   Portée volontairement limitée aux valeurs (reps/séries/repos…) : la structure
   (blocs, ordre, glisser-déposer) reste au compositeur, atteignable par le lien
   « Édition complète ». #}
{% import 'components/_activity.html.twig' as activity %}

{% if workout.blocks is empty %}
    <p class="kd-quickedit__empty">
        {{ ux_icon('lucide:layers') }}
        Cette séance n'a pas encore de bloc. Utilise l'édition complète pour la composer.
    </p>
{% else %}
    {% for block in workout.blocks|sort((a, b) => a.position <=> b.position) %}
        <section class="kd-quickblock">
            <header class="kd-quickblock__head">
                <span class="kd-quickblock__role">
                    {{ block.role.label }}{% if block.label %} · {{ block.label }}{% endif %}
                </span>
                {% if block.rounds > 1 %}
                    <span class="kd-quickblock__rounds">{{ ux_icon('lucide:repeat') }} {{ block.rounds }} tours</span>
                {% endif %}
            </header>

            {% for prescribed in block.prescribedExercises|sort((a, b) => a.position <=> b.position) %}
                {% set ex = prescribed.exercise %}
                {% set mod = ex ? activity.modifier(ex.activity) : '' %}
                <details class="kd-quickexo">
                    <summary class="kd-quickexo__sum">
                        <span class="kd-cexo__code{{ mod ? ' kd-cexo__code--' ~ mod }}">{{ ex ? ex.name|slice(0, 2)|upper : '??' }}</span>
                        <span class="kd-quickexo__name">{{ ex ? ex.name : 'Exercice supprimé' }}</span>
                        {% if summaries[prescribed.id]|default('') is not empty %}
                            <span class="kd-cexo__pill">{{ summaries[prescribed.id] }}</span>
                        {% endif %}
                        <span class="kd-quickexo__chevron">{{ ux_icon('lucide:chevron-down') }}</span>
                    </summary>
                    <div class="kd-quickexo__form">
                        {{ include('workout/_prescribed_form.html.twig', {
                            form: prescribedForms[prescribed.id],
                            submit_label: 'Enregistrer'
                        }) }}
                    </div>
                </details>
            {% else %}
                <p class="kd-quickblock__empty">Aucun exercice dans ce bloc.</p>
            {% endfor %}
        </section>
    {% endfor %}
{% endif %}
