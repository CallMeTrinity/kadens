{% extends 'base.html.twig' %}

{% block title %}Nouvelle séance{% endblock %}

{% block body %}
    <a href="{{ path('app_workout_index') }}" class="kd-backlink">
        {{ ux_icon('lucide:arrow-left') }} Mes séances
    </a>

    <div class="kd-pagehead">
        <div>
            <p class="kd-eyebrow">Séance</p>
            <h1 class="kd-title">Nouvelle séance</h1>
            <p class="kd-lead">Donne un titre et une durée estimée. Tu ajouteras les blocs et les exercices juste après.</p>
        </div>
    </div>

    <div class="kd-card" style="max-width:640px;">
        {{ form_start(form) }}
            {{ form_widget(form) }}
            <div class="kd-formactions">
                <button type="submit" class="kd-btn kd-btn--primary">
                    {{ ux_icon('lucide:plus') }} Créer la séance
                </button>
                <a href="{{ path('app_workout_index') }}" class="kd-btn kd-btn--ghost">Annuler</a>
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
