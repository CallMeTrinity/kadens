{% extends 'base.html.twig' %}

{% set workout = flat.workout %}

{% block title %}{{ workout.title }}{% endblock %}

{% block body %}
    {# Vue de consultation auto-suffisante : aucun chargement AJAX post-rendu,
       condition du cache offline (Phase 9). Consomme la sortie de PlanFlattener. #}
    <div class="kd-actionbar">
        <a href="{{ path('app_workout_index') }}" class="kd-backlink">
            {{ ux_icon('lucide:arrow-left') }} Mes séances
        </a>

        <div class="kd-actionbar__end"
             data-controller="clipboard"
             data-clipboard-url-value="{{ url('app_public_share', {slug: workout.slug}) }}">
            {% if is_granted('WORKOUT_EDIT', workout) %}
                <a href="{{ path('app_workout_edit', {id: workout.id}) }}" class="kd-btn kd-btn--secondary kd-btn--sm">
                    {{ ux_icon('lucide:square-pen') }} Éditer
                </a>
            {% endif %}
            <a href="{{ path('app_export_workout', {id: workout.id}) }}" class="kd-btn kd-btn--ghost kd-btn--sm">
                {{ ux_icon('lucide:file-down') }} Excel
            </a>
            <button type="button" class="kd-btn kd-btn--ghost kd-btn--sm" data-action="clipboard#copy">
                {{ ux_icon('lucide:link-2') }} Copier le lien
            </button>
            <a href="{{ path('app_public_share', {slug: workout.slug}) }}" target="_blank" rel="noopener"
               class="kd-btn kd-btn--ghost kd-btn--sm">
                {{ ux_icon('lucide:external-link') }} Page publique
            </a>
            <span class="kd-actionbar__feedback" data-clipboard-target="feedback" role="status" aria-live="polite"></span>
        </div>
    </div>

    {% include 'components/_workout_read.html.twig' with { flat: flat } only %}
{% endblock %}
